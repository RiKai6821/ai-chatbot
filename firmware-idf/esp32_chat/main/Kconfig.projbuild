# 本应用配置（WiFi 凭据在共享组件 bsp_wifi 的菜单里）。
menu "小智 Chat 配置"

    config XZ_SERVER_URL
        string "服务端 /chat 地址"
        default "http://192.168.1.10:8000/chat"
        help
            你电脑的局域网 IP；服务端启动要带 --host 0.0.0.0。

    config XZ_SESSION_ID
        string "会话 ID"
        default "esp32-idf-1"

endmenu
