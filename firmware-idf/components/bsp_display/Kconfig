# 共享组件配置：GC9A01 圆屏 SPI 引脚。
menu "BSP 显示（GC9A01 圆屏 SPI 引脚）"

    config XZ_TFT_SCLK
        int "TFT SCLK GPIO"
        default 12
    config XZ_TFT_MOSI
        int "TFT MOSI (SDA) GPIO"
        default 11
    config XZ_TFT_DC
        int "TFT DC GPIO"
        default 8
    config XZ_TFT_CS
        int "TFT CS GPIO"
        default 10
    config XZ_TFT_RST
        int "TFT RST GPIO"
        default 9
    config XZ_TFT_BL
        int "TFT 背光 BL GPIO（高电平亮）"
        default 14

endmenu
